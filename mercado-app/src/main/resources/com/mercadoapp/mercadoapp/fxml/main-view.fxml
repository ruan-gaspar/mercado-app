<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.mercadoapp.mercadoapp.controller.MainController"
           stylesheets="@../css/main.css"
           styleClass="app-root">

    <children>
        <VBox alignment="CENTER" spacing="18.0" styleClass="main-card" maxWidth="460.0">
            <padding>
                <Insets top="32.0" right="32.0" bottom="32.0" left="32.0"/>
            </padding>

            <Label text="Mercado App" styleClass="app-title"/>
            <Label text="Gerencie produtos, listas planejadas e compras realizadas"
                   wrapText="true"
                   styleClass="app-subtitle"/>

            <VBox spacing="12.0" fillWidth="true">

                <Button fx:id="plannedOrderButton"
                        text="Lista Planejada"
                        onAction="#openPlannedOrderScreen"
                        maxWidth="Infinity"
                        styleClass="menu-button"/>

                <Button fx:id="plannedOrderItemButton"
                        text="Itens da Lista Planejada"
                        onAction="#openPlannedOrderItemScreen"
                        maxWidth="Infinity"
                        styleClass="menu-button"/>

                <Button fx:id="orderButton"
                        text="Compras Realizadas"
                        onAction="#openOrderScreen"
                        maxWidth="Infinity"
                        styleClass="menu-button"/>

                <Button fx:id="orderItemButton"
                        text="Itens da Compra"
                        onAction="#openOrderItemScreen"
                        maxWidth="Infinity"
                        styleClass="menu-button"/>

                <Button fx:id="productButton"
                        text="Produtos"
                        onAction="#openProductScreen"
                        maxWidth="Infinity"
                        styleClass="menu-button"/>

                <Button fx:id="categoryButton"
                        text="Categorias"
                        onAction="#openCategoryScreen"
                        maxWidth="Infinity"
                        styleClass="menu-button"/>

                <Button fx:id="sectorButton"
                        text="Setores"
                        onAction="#openSectorScreen"
                        maxWidth="Infinity"
                        styleClass="menu-button"/>

            </VBox>
        </VBox>
    </children>
</StackPane>