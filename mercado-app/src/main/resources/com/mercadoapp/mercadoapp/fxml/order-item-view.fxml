<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.mercadoapp.mercadoapp.controller.OrderItemController"
           stylesheets="@../css/app.css"
           styleClass="app-root">

    <children>
        <VBox alignment="TOP_CENTER"
              spacing="18.0"
              styleClass="screen-card"
              maxWidth="1200.0">

            <padding>
                <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Button fx:id="backButton"
                        text="← Voltar"
                        onAction="#goBackToMain"
                        styleClass="secondary-button"/>

                <VBox spacing="4.0">
                    <Label text="Itens da Compra" styleClass="screen-title"/>
                    <Text text="Registre os produtos comprados, quantidade, preço unitário e subtotal."
                          styleClass="screen-subtitle"/>
                </VBox>
            </HBox>

            <GridPane hgap="12.0" vgap="12.0" maxWidth="Infinity">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="180.0"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="220.0"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="120.0"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0"/>
                </columnConstraints>

                <ComboBox fx:id="orderComboBox"
                          promptText="Selecione a compra"
                          maxWidth="Infinity"
                          GridPane.columnIndex="0"
                          GridPane.rowIndex="0"
                          styleClass="form-field"/>

                <ComboBox fx:id="productComboBox"
                          promptText="Selecione o produto"
                          maxWidth="Infinity"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="0"
                          styleClass="form-field"/>

                <TextField fx:id="orderItemQuantityField"
                           promptText="Quantidade"
                           maxWidth="Infinity"
                           GridPane.columnIndex="2"
                           GridPane.rowIndex="0"
                           styleClass="form-field"/>

                <TextField fx:id="orderItemUnitPriceField"
                           promptText="Preço unitário"
                           maxWidth="Infinity"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="0"
                           styleClass="form-field"/>

                <TextField fx:id="orderItemSubtotalField"
                           promptText="Subtotal"
                           editable="false"
                           focusTraversable="false"
                           maxWidth="Infinity"
                           GridPane.columnIndex="4"
                           GridPane.rowIndex="0"
                           styleClass="form-field"/>
            </GridPane>

            <HBox spacing="10.0">
                <Button text="Adicionar item"
                        onAction="#onAddOrderItem"
                        styleClass="primary-button"/>

                <Button text="Atualizar item"
                        onAction="#onUpdateOrderItem"
                        styleClass="secondary-button"/>

                <Button text="Remover item"
                        onAction="#onDeleteOrderItem"
                        styleClass="danger-button"/>
            </HBox>

            <TableView fx:id="orderItemTable"
                       prefHeight="460.0"
                       maxWidth="Infinity"
                       VBox.vgrow="ALWAYS"
                       styleClass="modern-table">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="70.0"/>
                    <TableColumn fx:id="orderIdColumn" text="Compra" prefWidth="180.0"/>
                    <TableColumn fx:id="productIdColumn" text="Produto" prefWidth="260.0"/>
                    <TableColumn fx:id="quantityColumn" text="Quantidade" prefWidth="140.0"/>
                    <TableColumn fx:id="unitPriceColumn" text="Preço unitário" prefWidth="180.0"/>
                    <TableColumn fx:id="subtotalColumn" text="Subtotal" prefWidth="180.0"/>
                </columns>
            </TableView>
        </VBox>
    </children>
</StackPane>